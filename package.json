{
  "name": "zrsystem-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend do projeto ZR System",
  "main": "dist/main/http/server.js",
  "scripts": {
    "dev": "tsx watch src/main/http/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main/http/server.js",
    "typeorm": "typeorm-ts-node-commonjs -d src/main/config/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/auto",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "dependencies": {
    "@scalar/express-api-reference": "^0.9.5",
    "bcryptjs": "3.0.3",
    "cors": "2.8.5",
    "dotenv": "17.4.0",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "openapi3-ts": "^4.5.0",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.28",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.5.0",
    "tsx": "4.21.0",
    "typeorm-ts-node-commonjs": "0.3.20",
    "typescript": "6.0.2"
  }
}
